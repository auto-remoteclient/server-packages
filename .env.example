# Your company backend (web UI + agent connect here). Outbound from the end-user server.
BACKEND_URL=wss://api.example.com

# Web UI base URL for the pairing page (used in install.sh success message; optional for the agent itself).
# FRONTEND_PAIR_BASE_URL=https://promptier.dev/pair

# Optional: extra directories to scan for projects (comma-separated). Relative paths resolve from cwd.
# SCAN_DIRS=/home/deploy/projects,/var/www
#
# Local monorepo test — only repo root ./playground (run from server-packages):
#   npm run start:local
# (sets SCAN_DIRS to …/playground and LOCAL_PLAYGROUND_ONLY=1)

# Optional: full path to claude CLI
# CLAUDE_BIN=/usr/local/bin/claude
